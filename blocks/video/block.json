{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sermonator/video",
  "title": "Sermon Video",
  "category": "media",
  "icon": "format-video",
  "description": "Embedded video for a sermon (stored embed code or a video URL).",
  "textdomain": "sermonator",
  "usesContext": [ "postId" ],
  "attributes": {
    "postId": { "type": "number" }
  },
  "supports": {
    "html": false,
    "align": [ "wide" ]
  },
  "style": "sermonator-frontend"
}
